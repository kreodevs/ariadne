# URL base del backend (API/Ingest). Sin trailing slash.
# Local: http://localhost:3002 (o 3000 si usas proxy API)
# Producción: https://apiariadne.kreoint.mx
VITE_API_URL=http://localhost:3002

# SSO (opcional). Si no se define VITE_SSO_APPLICATION_ID, la app funciona sin auth.
# VITE_SSO_BASE_URL=https://apisso.grupowib.com.mx/api/v1
# VITE_SSO_APPLICATION_ID=uuid-de-tu-app
# VITE_SSO_FRONTEND_URL=https://sso.grupowib.com.mx
