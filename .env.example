# Ariadne / AriadneSpecs — Plantilla de variables de entorno
# Copiar a .env y rellenar valores

# --- LLM (ingest + orchestrator): homologado ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=
# LLM_TEMPERATURE=1

# Embeddings (RAG) — independiente del LLM de chat salvo que uses el mismo proveedor
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
# GOOGLE_API_KEY=

# Kimi embeddings (si EMBEDDING_PROVIDER=kimi): MOONSHOT_API_KEY o KIMI_API_KEY
# Defaults en código: KIMI_EMBEDDING_MODEL=moonshot-v1, KIMI_EMBEDDING_DIMENSION=1024 (sobrescribir si tu API devuelve otra dimensión)
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# Orchestrator Kimi: 429 TPM → reintentos con espera larga (default ~58s). Opcional:
# MOONSHOT_TPM_RETRY_COOLDOWN_MS=58000
# LLM_MIN_REQUEST_INTERVAL_MS=2000
# LLM_MAX_CONCURRENT=1
# Chat (ingest + orchestrator): max_tokens en la fase retriever con tool_calls (evita JSON/Cypher truncados). Default 8192.
# CHAT_TOOL_CALL_MAX_TOKENS=8192
# KIMI_EMBEDDING_MODEL=moonshot-v1
# KIMI_EMBEDDING_DIMENSION=1024

# Legacy (opcional; si usas solo LLM_* arriba, puedes omitir)
# ORCHESTRATOR_LLM_PROVIDER=kimi
# INGEST_LLM_PROVIDER=kimi
# CHAT_MODEL=gpt-4o-mini

# Credenciales cifradas en BD
CREDENTIALS_ENCRYPTION_KEY=

# Providers (opcional; credenciales en BD preferible)
# GITHUB_TOKEN=
# BITBUCKET_USER=
# BITBUCKET_APP_PASSWORD=
# Bitbucket App Password: Account:Read, Workspace membership:Read, Repositories:Read (ver docs/manual)

# FalkorDB (opcional)
# FALKORDB_BATCH_SIZE=500
# API: ejecutor Cypher debug en explorador de grafo (docker-compose pasa esto al servicio api)
# FALKOR_DEBUG_CYPHER=1
# DOMAIN_* — fallback global si el proyecto no tiene domain_config. Por defecto se infiere en la primera ingesta.

# --- Producción (Dokploy: un solo dominio ariadne.kreoint.mx) ---
# CORS_ORIGIN=https://ariadne.kreoint.mx
# VITE_API_URL=https://ariadne.kreoint.mx

# --- Auth OTP ---
# JWT_SECRET=  (obligatorio en prod)
# OTP_DEV_MODE=true  (dev: devuelve código en respuesta)
# EMAIL_OTP=  (opcional: solo ese email puede solicitar OTP)

# --- SMTP (envío OTP) ---
# SMTP_HOST=mail.kreoint.mx
# SMTP_PORT=587
# SMTP_USER=hola@kreoint.mx
# SMTP_PASS=
# SMTP_FROM=Servicio de aplicaciones
