# Ariadne / AriadneSpecs — Plantilla de variables de entorno
# Copiar a .env y rellenar valores

# --- LLM / OpenRouter —  sola variable de clave es LLM_API_KEY ---
# Clave obligatoria para chat, análisis y embeddings.
LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
# Chat: default en código = nousresearch/hermes-3-llama-3.1-405b (The Forge)
# LLM_CHAT_MODEL=nousresearch/hermes-3-llama-3.1-405b
# Embeddings RAG: default openai/text-embedding-3-small (1536 dims)
# LLM_EMBEDDING_MODEL=openai/text-embedding-3-small
# OPENAI_EMBEDDING_DIM=1536
# LLM_HTTP_REFERER=
# LLM_APP_TITLE=

# LLM_PROVIDER — Proveedor LLM. Default: openrouter. En el futuro: lemondata, etc.
# Cada servicio (ingest, orchestrator) lee esta misma variable.
LLM_PROVIDER=openrouter

# LLM_MODEL_INGEST — Modelo para el servicio de ingest. Prioridad sobre LLM_MODEL y LLM_CHAT_MODEL.
# Si no se define, usa LLM_MODEL → LLM_CHAT_MODEL → nousresearch/hermes-3-llama-3.1-405b.
# LLM_MODEL_INGEST=deepseek/deepseek-v4-flash

# ORCHESTRATOR_LLM_MODEL — Modelo para el orquestador (LangGraph). Prioridad sobre LLM_MODEL y LLM_CHAT_MODEL.
# Si no se define, usa LLM_MODEL → LLM_CHAT_MODEL → default.
# ORCHESTRATOR_LLM_MODEL=deepseek/deepseek-v4-flash

# Embeddings: solo openrouter (openai se acepta como alias hacia el mismo API)
EMBEDDING_PROVIDER=openrouter
# CHAT_MODEL=

# Chat (ingest + orchestrator): max_tokens fase retriever con tool_calls. Default 8192.
# CHAT_TOOL_CALL_MAX_TOKENS=8192

# Credenciales cifradas en BD
CREDENTIALS_ENCRYPTION_KEY=

# Providers (opcional; credenciales en BD preferible)
# GITHUB_TOKEN=
# BITBUCKET_USER=
# BITBUCKET_APP_PASSWORD=
# Bitbucket App Password: Account:Read, Workspace membership:Read, Repositories:Read (ver docs/manual)

# FalkorDB (opcional)
# FALKORDB_BATCH_SIZE=500
# API: ejecutor Cypher debug en explorador de grafo (docker-compose pasa esto al servicio api)
# FALKOR_DEBUG_CYPHER=1
# DOMAIN_* — fallback global si el proyecto no tiene domain_config. Por defecto se infiere en la primera ingesta.

# --- Producción (Dokploy: un solo dominio ariadne.kreoint.mx) ---
# CORS_ORIGIN=https://ariadne.kreoint.mx
# VITE_API_URL=https://ariadne.kreoint.mx

# --- Auth OTP ---
# JWT_SECRET=  (obligatorio en prod)
# OTP_DEV_MODE=true  (dev: devuelve código en respuesta)
# EMAIL_OTP=  (opcional: solo ese email puede solicitar OTP)

# --- SMTP (envío OTP) ---
# SMTP_HOST=mail.kreoint.mx
# SMTP_PORT=587
# SMTP_USER=hola@kreoint.mx
# SMTP_PASS=
# SMTP_FROM=Servicio de aplicaciones

# --- Redis y rendimiento (operadores) ---
# Misma REDIS_URL en ingest (cola BullMQ sync), api (caché impact/component/contract/C4 si está definida),
# orchestrator (estado codebase:chat / refactor), MCP opcional (MCP_REDIS_URL o REDIS_URL para caché de herramientas).
# REDIS_URL=redis://localhost:6380
#
# Ingest: caché distribuida opcional de POST …/analyze — ANALYZE_CACHE_REDIS_URL o REDIS_URL (ver ingest .env / código).
# MCP Ariadne: MCP_ASK_CODEBASE_TIMEOUT_MS (timeout del fetch hacia ingest en ask_codebase); en logs,
# MCP_ASK_CODEBASE_PROGRESS_LOG_MS (default 60000) emite mcp_tool_call_progress mientras dura la petición.
#
# --- Multi-usuario / RBAC ---
# Primer usuario en loguearse se crea automáticamente con rol 'developer'.
# Para asignar admin inicial, usa PATCH /users/:id/role via API directa.
# o configura VITE_SSO_URL en frontend para SSO.
#
# --- SSO (opcional) ---
# Si SSO_URL está definida, el login delegará en ese endpoint.
# SSO_URL debe exponer POST /verify que recibe { token } y devuelve { email, role, name }.
# Adicional, VITE_SSO_URL debe configurarse en el frontend para el botón de SSO.
# SSO_URL=
#
# --- MCP tokens por usuario ---
# Ya no es necesario MCP_AUTH_TOKEN estático. Cada usuario genera su token en /profile.
# Si MCP_AUTH_TOKEN se mantiene, funciona como fallback para backward compat.
