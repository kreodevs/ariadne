# Ariadne / FalkorSpecs — Plantilla de variables de entorno
# Copiar a .env y rellenar valores

# Embeddings (RAG)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
# CHAT_MODEL=gpt-4o-mini
# GOOGLE_API_KEY=

# Credenciales cifradas en BD
CREDENTIALS_ENCRYPTION_KEY=

# Providers (opcional; credenciales en BD preferible)
# GITHUB_TOKEN=
# BITBUCKET_USER=
# BITBUCKET_APP_PASSWORD=
# Bitbucket App Password: Account:Read, Workspace membership:Read, Repositories:Read (ver docs/manual)

# FalkorDB (opcional)
# FALKORDB_BATCH_SIZE=500
# DOMAIN_* — fallback global si el proyecto no tiene domain_config. Por defecto se infiere en la primera ingesta.

# --- Producción (Dokploy: un solo dominio ariadne.kreoint.mx) ---
# CORS_ORIGIN=https://ariadne.kreoint.mx
# VITE_API_URL=https://ariadne.kreoint.mx

# --- SSO (opcional) ---
# Frontend (build args)
# VITE_SSO_APPLICATION_ID=uuid-de-tu-app
# VITE_SSO_BASE_URL=https://apisso.grupowib.com.mx/api/v1
# VITE_SSO_FRONTEND_URL=https://sso.grupowib.com.mx
# API (JWT + M2M)
# SSO_APPLICATION_ID=uuid-de-tu-app
# SSO_JWKS_URI=https://apisso.grupowib.com.mx/api/v1/auth/jwks
# MCP (validación M2M con SSO). Usar apisso (API), NO sso (frontend login).
# SSO_API_URL=https://apisso.grupowib.com.mx/api/v1
# O dejar vacío y el MCP infiere desde SSO_JWKS_URI (misma URL que la API).
# APPLICATION_ID=uuid-de-tu-app  (o SSO_APPLICATION_ID si coincide con la API)
# MCP_TOKEN_CACHE_TTL_SEC=300  (segundos que se cachea un token válido; evita 429 rate limit)
# MCP_AUTH_TOKEN= (legacy, si no usas SSO)
