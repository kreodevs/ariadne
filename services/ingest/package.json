{
  "name": "ariadnespec-ingest",
  "version": "1.2.0",
  "description": "Microservicio de ingesta: repositorios remotos (Bitbucket) + full sync + webhook",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typeorm": "typeorm-ts-node-esm -d src/data-source.ts",
    "migration:run": "npm run build && node ./node_modules/typeorm/cli.js migration:run -d dist/data-source.js"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@prisma/internals": "^6.19.2",
    "ariadne-common": "file:../../packages/ariadne-common",
    "bullmq": "^5.70.0",
    "falkordb": "^6.0.0",
    "ioredis": "^5.9.3",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tree-sitter": "^0.21.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "typeorm": "^0.3.20",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
