# API FalkorSpecs — variables de entorno
# CORS_ORIGIN=http://localhost:5173,https://ariadne.kreoint.mx
# PORT=3000
# INGEST_URL=http://localhost:3002

# Auth OTP
# JWT_SECRET=  (obligatorio en prod)
# OTP_DEV_MODE=true  (dev: devuelve código en respuesta)
# EMAIL_OTP=  (opcional: whitelist; si se define, solo ese email puede solicitar OTP)

# SMTP (envío real de OTP)
# SMTP_HOST=mail.kreoint.mx
# SMTP_PORT=587
# SMTP_USER=hola@kreoint.mx
# SMTP_PASS=
# SMTP_FROM=Servicio de aplicaciones
# M2M: el MCP y otros servicios usan X-M2M-Token o Authorization: Bearer m2m_xxx
